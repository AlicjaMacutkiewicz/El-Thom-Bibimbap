  <datatypes>
    <type source="customexpression">
      <name>Corrective moment coefficient</name>
      <symbol>Ccm</symbol>
      <unit unittype="auto">N*m/rad</unit>
      <expression> Vt  ^ 2* Ar  * ( Cn / α ) * ( Cp   -  Cg ) * ( P  / (287.058 *  T )) / 2 </expression>
    </type>
    <type source="customexpression">
      <name>Damping ratio</name>
      <symbol>ζ</symbol>
      <unit unittype="auto"></unit>
      <expression> Cdm  / (2 *  sqrt( Il  *  Ccm ) )</expression>
    </type>
    <type source="customexpression">
      <name>Dynamic pressure</name>
      <symbol>Q</symbol>
      <unit unittype="auto">Pa</unit>
      <expression>0.5 *  Vt  ^ 2 *  P  / (  T  * 287)</expression>
    </type>
    <type source="customexpression">
      <name>Max-Q</name>
      <symbol>Qm</symbol>
      <unit unittype="auto">Pa</unit>
      <expression> max( Q[:]) </expression>
    </type>
    <type source="customexpression">
      <name>Max-Q time</name>
      <symbol>tQm</symbol>
      <unit unittype="auto">s</unit>
      <expression> tnear(Q[:],Qm) </expression>
    </type>
  </datatypes>

